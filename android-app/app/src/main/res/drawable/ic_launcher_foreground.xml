<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Halo / glow autour du bolt (très transparent) -->
    <path
        android:fillColor="#33F97316"
        android:pathData="M 64,12 L 22,60 L 46,60 L 36,98 L 84,46 L 60,46 Z" />

    <!-- Bolt principal — orange vif Marvin -->
    <path android:pathData="M 64,16 L 26,60 L 48,60 L 38,94 L 80,48 L 60,48 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="26" android:startY="16"
                android:endX="80" android:endY="94">
                <item android:offset="0.0" android:color="#FFB347" />
                <item android:offset="0.5" android:color="#F97316" />
                <item android:offset="1.0" android:color="#DC2626" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Highlight intérieur — touche brillante -->
    <path
        android:fillColor="#80FFFFFF"
        android:pathData="M 60,22 L 36,56 L 46,56 L 42,72 L 56,52 L 50,52 Z" />

    <!-- Trois petites barres tranchantes en bas — détail combat / vitesse -->
    <path android:fillColor="#F97316"
          android:pathData="M 18,98 L 30,92 L 30,96 L 22,100 Z" />
    <path android:fillColor="#F97316"
          android:pathData="M 32,100 L 44,94 L 44,98 L 36,102 Z" />
</vector>

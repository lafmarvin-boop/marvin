<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:layout_marginBottom="12dp">
        <Button android:id="@+id/preset16"  style="@style/SmallButton" android:text="16×16"  android:layout_columnWeight="1" android:layout_margin="2dp"/>
        <Button android:id="@+id/preset24"  style="@style/SmallButton" android:text="24×24"  android:layout_columnWeight="1" android:layout_margin="2dp"/>
        <Button android:id="@+id/preset32"  style="@style/SmallButton" android:text="32×32"  android:layout_columnWeight="1" android:layout_margin="2dp"/>
        <Button android:id="@+id/preset48"  style="@style/SmallButton" android:text="48×48"  android:layout_columnWeight="1" android:layout_margin="2dp"/>
        <Button android:id="@+id/preset64"  style="@style/SmallButton" android:text="64×64"  android:layout_columnWeight="1" android:layout_margin="2dp"/>
        <Button android:id="@+id/preset128" style="@style/SmallButton" android:text="128×128" android:layout_columnWeight="1" android:layout_margin="2dp"/>
    </GridLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView style="@style/Caption" android:text="@string/width"/>
            <EditText android:id="@+id/inputW" android:inputType="number" android:text="32" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="@style/Caption" android:text="@string/height"/>
            <EditText android:id="@+id/inputH" android:inputType="number" android:text="32" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

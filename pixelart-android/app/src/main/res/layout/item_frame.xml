<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/frameRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/panel_bg"
    android:padding="4dp"
    android:layout_marginVertical="2dp">

    <ImageView
        android:id="@+id/frameThumb"
        android:layout_width="@dimen/frame_thumb_size"
        android:layout_height="@dimen/frame_thumb_size"
        android:scaleType="fitCenter"
        android:background="@color/bg" />

    <TextView
        android:id="@+id/frameLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingHorizontal="6dp"
        android:textColor="@color/text"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnUp"
            android:layout_width="32dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_arrow_upward"
            android:scaleType="fitCenter"
            android:padding="2dp"
            android:background="@color/bg_panel"
            android:contentDescription="Monter la frame" />
        <ImageButton
            android:id="@+id/btnDown"
            android:layout_width="32dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_arrow_downward"
            android:scaleType="fitCenter"
            android:padding="2dp"
            android:background="@color/bg_panel"
            android:contentDescription="Descendre la frame"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>

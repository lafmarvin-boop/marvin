<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/bg_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton android:id="@+id/btnMenu" style="@style/TopBarButton"
            android:src="@drawable/ic_menu" android:contentDescription="@string/menu"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/app_name"
            android:textColor="@color/accent_light" android:textSize="16sp"
            android:textStyle="bold" android:gravity="center" android:letterSpacing="0.05" />

        <ImageButton android:id="@+id/btnSymmetry" style="@style/TopBarButton"
            android:src="@drawable/ic_symmetry" android:contentDescription="@string/symmetry"/>
        <ImageButton android:id="@+id/btnMagic" style="@style/TopBarButton"
            android:src="@drawable/ic_magic" android:contentDescription="@string/generate_animation"/>
        <ImageButton android:id="@+id/btnUndo" style="@style/TopBarButton"
            android:src="@drawable/ic_undo" android:contentDescription="@string/undo"/>
        <ImageButton android:id="@+id/btnRedo" style="@style/TopBarButton"
            android:src="@drawable/ic_redo" android:contentDescription="@string/redo"/>
        <ImageButton android:id="@+id/btnPlay" style="@style/TopBarButton"
            android:src="@drawable/ic_play" android:contentDescription="@string/play"/>
    </LinearLayout>

    <!-- LEFT TOOLBAR -->
    <ScrollView
        android:id="@+id/leftBar"
        android:layout_width="52dp"
        android:layout_height="0dp"
        android:background="@color/bg_dark"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="4dp">

            <ImageButton android:id="@+id/toolPencil"    style="@style/ToolButton" android:src="@drawable/ic_pencil"/>
            <ImageButton android:id="@+id/toolEraser"    style="@style/ToolButton" android:src="@drawable/ic_eraser"/>
            <ImageButton android:id="@+id/toolFill"      style="@style/ToolButton" android:src="@drawable/ic_fill"/>
            <ImageButton android:id="@+id/toolPicker"    style="@style/ToolButton" android:src="@drawable/ic_picker"/>
            <ImageButton android:id="@+id/toolLine"      style="@style/ToolButton" android:src="@drawable/ic_line"/>
            <ImageButton android:id="@+id/toolRect"      style="@style/ToolButton" android:src="@drawable/ic_rect"/>
            <ImageButton android:id="@+id/toolRectFill"  style="@style/ToolButton" android:src="@drawable/ic_rect_fill"/>
            <ImageButton android:id="@+id/toolSelect"    style="@style/ToolButton" android:src="@drawable/ic_select"/>
            <ImageButton android:id="@+id/toolWand"      style="@style/ToolButton" android:src="@drawable/ic_wand"/>
            <ImageButton android:id="@+id/toolMove"      style="@style/ToolButton" android:src="@drawable/ic_move"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/bg_panel" android:layout_marginVertical="6dp" />

            <ImageButton android:id="@+id/btnClear" style="@style/ToolButton" android:src="@drawable/ic_clear"/>
            <ImageButton android:id="@+id/btnGrid"  style="@style/ToolButton" android:src="@drawable/ic_grid"/>
            <ImageButton android:id="@+id/btnFlip"  style="@style/ToolButton" android:src="@drawable/ic_flip"/>
        </LinearLayout>
    </ScrollView>

    <!-- CANVAS -->
    <com.pixelhero.app.PixelCanvasView
        android:id="@+id/canvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toEndOf="@id/leftBar"
        app:layout_constraintEnd_toStartOf="@id/rightPanel"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- RIGHT PANEL -->
    <ScrollView
        android:id="@+id/rightPanel"
        android:layout_width="240dp"
        android:layout_height="0dp"
        android:background="@color/bg_dark"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Color section -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/panel_bg"
                android:padding="10dp" android:layout_marginBottom="8dp">

                <TextView style="@style/SectionTitle" android:text="Couleur"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View android:id="@+id/currentColorSwatch"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:background="#FF5577"/>

                    <ImageButton android:id="@+id/btnSwap"
                        android:src="@drawable/ic_swap"
                        android:background="@drawable/tool_button_bg"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_marginHorizontal="4dp"
                        android:tint="@color/text"
                        android:contentDescription="@string/swap_colors"/>

                    <View android:id="@+id/secondaryColorSwatch"
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:background="#000000"/>

                    <TextView android:id="@+id/currentColorHex"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="#FF5577"
                        android:textColor="@color/text" android:fontFamily="monospace"
                        android:paddingHorizontal="6dp" android:textSize="11sp"/>

                    <Button android:id="@+id/btnPickColor"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="…" android:textColor="@color/text"
                        android:backgroundTint="@color/bg_panel"
                        android:minWidth="0dp" android:paddingHorizontal="12dp"
                        android:insetTop="0dp" android:insetBottom="0dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView android:id="@+id/paletteList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:overScrollMode="never"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <Button android:id="@+id/btnAutoShade" style="@style/SmallButton"
                        android:text="@string/auto_shade" android:layout_weight="1"/>
                    <Button android:id="@+id/btnPaletteLib" style="@style/SmallButton"
                        android:text="@string/palette_library"
                        android:layout_marginStart="4dp" android:layout_weight="1"/>
                </LinearLayout>
                <Button android:id="@+id/btnReplaceColor" style="@style/SmallButton"
                    android:text="@string/replace_color"
                    android:layout_width="match_parent" android:layout_marginTop="4dp"/>

                <TextView style="@style/SectionSubtitle" android:text="Récentes"
                    android:layout_marginTop="6dp"/>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recentList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:overScrollMode="never"/>
            </LinearLayout>

            <!-- Background reference + Onion -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/panel_bg"
                android:padding="10dp" android:layout_marginBottom="8dp">

                <TextView style="@style/SectionTitle" android:text="@string/bg_reference"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnBgLoad" style="@style/SmallButton"
                        android:text="@string/bg_load" android:layout_weight="1"/>
                    <Button android:id="@+id/btnBgClear" style="@style/SmallButton"
                        android:text="@string/bg_clear" android:layout_marginStart="4dp"
                        android:layout_weight="1"/>
                </LinearLayout>

                <Button android:id="@+id/btnBgFit" style="@style/SmallButton"
                    android:text="Mode : Remplir"
                    android:layout_width="match_parent"
                    android:layout_marginTop="4dp"/>

                <TextView style="@style/Caption" android:text="@string/opacity"
                    android:layout_marginTop="6dp"/>
                <SeekBar android:id="@+id/bgOpacity"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50"/>

                <TextView style="@style/Caption" android:text="@string/onion_range"/>
                <SeekBar android:id="@+id/onionRange"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="3" android:progress="1"/>

                <CheckBox android:id="@+id/cbPixelPerfect"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/pixel_perfect"
                    android:textColor="@color/text" android:buttonTint="@color/accent"/>

                <TextView style="@style/Caption" android:text="Taille du pinceau"
                    android:layout_marginTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <SeekBar android:id="@+id/brushSize"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="9" android:progress="0"/>
                    <TextView android:id="@+id/brushSizeLabel"
                        android:layout_width="32dp" android:layout_height="wrap_content"
                        android:text="1px" android:textColor="@color/text" android:textSize="11sp"
                        android:gravity="end"/>
                </LinearLayout>

                <TextView style="@style/Caption" android:text="Tramage"
                    android:layout_marginTop="4dp"/>
                <Button android:id="@+id/btnDither" style="@style/SmallButton"
                    android:text="Aucun" android:layout_width="match_parent"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <CheckBox android:id="@+id/cbSketchMode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mode croquis" android:textColor="@color/text"
                        android:buttonTint="@color/accent" android:layout_weight="1"/>
                    <Button android:id="@+id/btnSketchBake" style="@style/SmallButton"
                        android:text="Valider" android:layout_marginEnd="2dp"/>
                    <Button android:id="@+id/btnSketchClear" style="@style/SmallButton"
                        android:text="✕" android:minWidth="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Zoom controls -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp"
                android:background="@drawable/panel_bg" android:padding="8dp">
                <Button android:id="@+id/btnZoomOut" style="@style/SmallButton"
                    android:text="−" android:layout_weight="1"/>
                <Button android:id="@+id/btnZoomFit" style="@style/SmallButton"
                    android:text="Adapter" android:layout_weight="1" android:layout_marginStart="4dp"/>
                <Button android:id="@+id/btnZoomIn" style="@style/SmallButton"
                    android:text="+" android:layout_weight="1" android:layout_marginStart="4dp"/>
                <Button android:id="@+id/btnZoom100" style="@style/SmallButton"
                    android:text="1×" android:layout_weight="1" android:layout_marginStart="4dp"/>
                <Button android:id="@+id/btnZoom400" style="@style/SmallButton"
                    android:text="4×" android:layout_weight="1" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Frames -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/panel_bg"
                android:padding="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <TextView style="@style/SectionTitle" android:text="@string/frames"
                        android:layout_weight="1"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/fps" android:textColor="@color/text_dim"
                        android:textSize="11sp" android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/fpsInput"
                        android:layout_width="48dp" android:layout_height="32dp"
                        android:inputType="number" android:text="8"
                        android:textColor="@color/text" android:background="@color/bg"
                        android:gravity="center" android:padding="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp"
                    android:gravity="center_vertical">
                    <TextView style="@style/Caption" android:text="Aperçu :"/>
                    <ImageView android:id="@+id/miniPreview"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:layout_marginStart="8dp"
                        android:background="@color/bg"
                        android:scaleType="fitCenter"/>
                    <Button android:id="@+id/btnPreviewToggle" style="@style/SmallButton"
                        android:text="Stop" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView android:id="@+id/framesList"
                    android:layout_width="match_parent" android:layout_height="200dp"
                    android:background="@color/bg" android:padding="4dp"
                    android:layout_marginTop="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <Button android:id="@+id/btnFrameAdd" style="@style/SmallButton"
                        android:text="@string/add_frame" android:layout_weight="1"/>
                    <Button android:id="@+id/btnFrameDup" style="@style/SmallButton"
                        android:text="@string/duplicate" android:layout_marginStart="4dp"
                        android:layout_weight="1"/>
                    <Button android:id="@+id/btnFrameDel" style="@style/SmallButton"
                        android:text="@string/delete" android:layout_marginStart="4dp"
                        android:backgroundTint="@color/danger" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

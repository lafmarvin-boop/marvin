<resources>
    <style name="TopBarButton">
        <item name="android:layout_width">@dimen/top_bar_button_size</item>
        <item name="android:layout_height">@dimen/top_bar_button_size</item>
        <item name="android:background">@drawable/tool_button_bg</item>
        <item name="android:scaleType">center</item>
        <item name="android:tint">@color/text</item>
    </style>

    <style name="ToolButton">
        <item name="android:layout_width">@dimen/tool_button_size</item>
        <item name="android:layout_height">@dimen/tool_button_size</item>
        <item name="android:background">@drawable/tool_button_bg</item>
        <item name="android:scaleType">center</item>
        <item name="android:tint">@color/text</item>
        <item name="android:layout_marginVertical">3dp</item>
    </style>

    <style name="SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/accent_light</item>
        <item name="android:textSize">@dimen/section_title_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="SectionSubtitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">@dimen/caption_text_size</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Caption">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:textSize">@dimen/caption_text_size</item>
    </style>

    <style name="SmallButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/small_button_height</item>
        <item name="android:textSize">@dimen/small_button_text_size</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="backgroundTint">@color/bg_panel_2</item>
    </style>
</resources>

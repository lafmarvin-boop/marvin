    <!-- Anneau intérieur -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#E1F5FE"
        android:fillColor="#1A3358"
        android:pathData="M 54,40 a 14,14 0 1,1 0,28 a 14,14 0 1,1 0,-28 Z" />

    <!-- Cœur triangulaire (énergie) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,46 L 62,60 L 46,60 Z" />

    <!-- Point lumineux central -->
    <path

            android:strokeWidth="1.5"
            android:strokeColor="#80D8FF"
            android:fillColor="#00000000"
            android:pathData="M 54,32 L 54,40" />
    </group>
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="240">
        <path
            android:strokeWidth="1.5"
            android:strokeColor="#80D8FF"
            android:fillColor="#00000000"
            android:pathData="M 54,32 L 54,40" />
    </group>
    <group
        android:pivotX="54"
        android:pivotY="54"
